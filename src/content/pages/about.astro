---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="About">
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-3xl px-8">
      <h1
        data-editable="source"
        data-path="src/content/pages/about.astro"
        data-key="heading"
        class="text-3xl md:text-5xl font-bold mb-8 text-balance">
        About Us
      </h1>
      <div
        data-editable="source"
        data-path="src/content/pages/about.astro"
        data-key="description"
        class="prose text-lg text-gray-600">
        <p>
          We're a small team passionate about building great websites. This page
          is a standalone Astro component edited with
          <strong>source editables</strong> — the content you see here lives directly
          in the template and is edited visually through CloudCannon.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-gray-50">
    <div class="mx-auto max-w-3xl px-8">
      <h2
        data-editable="source"
        data-path="src/content/pages/about.astro"
        data-key="contact_heading"
        class="text-2xl md:text-3xl font-bold mb-6 text-balance">
        Get in Touch
      </h2>
      <div
        data-editable="source"
        data-path="src/content/pages/about.astro"
        data-key="contact_details"
        class="prose text-lg text-gray-600">
        <p>
          Have a question or want to work together? Reach out at
          <a href="mailto:hello@example.com">hello@example.com</a>
          or find us on <a href="https://github.com">GitHub</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>
