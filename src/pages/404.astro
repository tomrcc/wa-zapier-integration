---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Not Found">
  <section class="flex flex-col items-center justify-center min-h-[60vh] px-8">
    <img src="/images/404.png" alt="Error illustration" class="max-w-sm mb-8" />
    <h1 class="text-3xl md:text-4xl font-bold mb-4">Page not found!</h1>
    <a href="/" class="text-blue-600 hover:text-blue-800 font-medium text-lg">
      &larr; Back home
    </a>
  </section>
</Layout>
