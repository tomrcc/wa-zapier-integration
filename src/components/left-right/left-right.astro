---
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import Markdown from "../utility/markdown.astro";

interface Props {
  heading: string;
  text_content: string;
  image: {
    image_path: string;
    alt_text: string;
  };
  flipped?: boolean;
  button?: {
    text: string;
    link: string;
  };
}

const { heading, text_content, image, flipped, button } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,svg,webp,avif}",
  { eager: true },
);
const imageSrc = images[image.image_path]?.default ?? image.image_path;
---

<section class="py-12 md:py-20">
  <div
    class={`mx-auto max-w-6xl px-8 flex flex-col md:flex-row items-center gap-12 ${flipped ? "md:flex-row-reverse" : ""}`}>
    <div class="flex-1 flex flex-col gap-4">
      <h2
        data-editable="text"
        data-prop="heading"
        class="text-2xl md:text-4xl font-bold leading-tight text-balance">
        {heading}
      </h2>
      <div class="text-gray-600">
        <Markdown
          content={text_content}
          dataProp="text_content"
          dataType="block"
        />
      </div>
      {
        button?.link && (
          <a
            href={button.link}
            class="mt-2 inline-block w-fit rounded-lg bg-blue-600 px-6 py-3 text-white font-medium hover:bg-blue-700 transition-colors">
            <span data-editable="text" data-prop="button.text">
              {button.text}
            </span>
          </a>
        )
      }
    </div>
    {
      image.image_path && image.alt_text && (
        <div class="flex-1">
          <Picture
            data-editable="image"
            data-prop-src="image.image_path"
            data-prop-alt="image.alt_text"
            alt={image.alt_text}
            src={imageSrc}
            class="w-full rounded-lg"
            loading="lazy"
            widths={[600, 800, 1200]}
            sizes="(max-width: 1200px) 100vw, 600px"
            formats={["avif", "webp"]}
          />
        </div>
      )
    }
  </div>
</section>
