---
import site from "data/site.json";
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";

interface Props {
  heading: string;
  date: string | Date;
  author: string;
  image: string;
  image_alt: string;
  tags: Array<string>;
  bodyContent: string;
}

const { heading, date, author, image, image_alt, tags, bodyContent } =
  Astro.props;

const wordCount = bodyContent?.split(" ")?.length ?? 0;
const dateObj = new Date(date);
const authorWithFallback = author || site.default_author;

let readingTime = "Less than 1 minute";
const readingTimeInMins = Math.floor(wordCount / 183);
if (readingTimeInMins === 1) {
  readingTime = "1 minute";
} else if (readingTimeInMins > 1) {
  readingTime = `${readingTimeInMins} minutes`;
}

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,svg,avif,webp}",
  { eager: true },
);
const imageSrc = images[image]?.default || image;
---

<div class="flex flex-col">
  {
    image && image_alt && (
      <Picture
        data-editable="image"
        data-prop-src="image"
        data-prop-alt="image_alt"
        class="w-full rounded-lg aspect-video object-cover"
        src={imageSrc}
        alt={image_alt}
        widths={[600, 800, 1200]}
        sizes="(max-width: 1200px) 100vw, 1200px"
        loading="eager"
        formats={["avif", "webp"]}
      />
    )
  }
  <h1
    data-editable="text"
    data-prop="heading"
    class="text-3xl md:text-4xl font-bold mt-4 mb-2 text-balance">
    {heading}
  </h1>
  {
    tags?.length > 0 && (
      <div class="flex flex-wrap gap-2 my-2">
        {tags.map((tag: string) => (
          <a
            href={`/tags/${tag}/`}
            class="bg-gray-100 text-blue-600 text-xs font-medium px-3 py-1 rounded-md no-underline">
            {tag.charAt(0).toUpperCase() + tag.slice(1)}
          </a>
        ))}
      </div>
    )
  }
  <div class="flex flex-col gap-1 py-4 text-sm text-gray-500">
    <p data-editable="text" data-prop="author">{authorWithFallback}</p>
    {
      dateObj && (
        <p>
          {dateObj.toLocaleDateString(undefined, {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </p>
      )
    }
    <p>{wordCount} words &middot; {readingTime}</p>
  </div>
</div>
