---
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";

const { data, id, loading } = Astro.props;
const { title, thumb_image_path, thumb_image_alt, post_hero } = data;
const { date, tags } = post_hero;

const dateObj = new Date(date);
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,svg,avif}",
  { eager: true },
);
const imageSrc = images[thumb_image_path]?.default ?? thumb_image_path;
---

<div class="flex flex-col">
  <a href={`/blog/${id}`}>
    <Picture
      class="w-full rounded-md aspect-video object-cover"
      src={imageSrc}
      alt={thumb_image_alt}
      widths={[600, 800]}
      sizes="(max-width: 800px) 100vw, 800px"
      loading={loading}
      formats={["avif", "webp"]}
    />
  </a>
  <div class="mt-3">
    {tags?.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-2">
        {tags.map((tag: string) => (
          <a
            href={`/tags/${tag}/`}
            class="bg-gray-100 text-blue-600 text-xs font-medium px-2 py-1 rounded no-underline"
          >
            {tag.charAt(0).toUpperCase() + tag.slice(1)}
          </a>
        ))}
      </div>
    )}
    <h2 class="text-lg font-semibold">
      <a href={`/blog/${id}/`} class="hover:text-blue-600 transition-colors">
        {title}
      </a>
    </h2>
    <p class="text-sm text-gray-500 mt-1">
      {dateObj.toLocaleDateString(undefined, {
        year: "numeric",
        month: "long",
        day: "numeric",
      })}
    </p>
  </div>
</div>
