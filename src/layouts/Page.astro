---
import Layout, { type SEOProps } from "./Layout.astro";

type Props = {
  frontmatter: {
    title: string;
    content_blocks: any[];
    hero_block: any;
    seo?: SEOProps;
  };
};

const props = Astro.props.frontmatter;

const components: Record<string, Function> = {};
const componentImports = import.meta.glob("../components/**/*.astro", {
  eager: true,
});

const componentMap: Record<string, string> = {
  Hero: "heroes/hero/hero",
  LeftRight: "left-right/left-right",
  TextBlock: "text-block/text-block",
};

Object.entries(componentImports).forEach(([path, obj]) => {
  const relativePath = path.replace("../components/", "").replace(".astro", "");
  const entry = Object.entries(componentMap).find(([, v]) => v === relativePath);
  if (entry) {
    components[entry[0]] = (obj as any).default;
  }
});

const HeroComponent = props.hero_block?._name ? components[props.hero_block._name] : null;
---

<Layout {...props}>
  {HeroComponent && (
    <editable-component data-prop="hero_block" data-component={props.hero_block._name}>
      <HeroComponent {...props.hero_block} />
    </editable-component>
  )}

  {props.content_blocks?.length > 0 && (
    <div data-editable="array" data-prop="content_blocks" data-id-key="_name" data-component-key="_name">
      {props.content_blocks.map((block) => {
        const Component = components[block._name];
        if (!Component) return null;
        return (
          <section data-editable="array-item" data-id={block._name} data-component={block._name}>
            <Component {...block} />
          </section>
        );
      })}
    </div>
  )}
</Layout>
